{
  "name": "ctrl-q-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VitePress documentation site for Ctrl-Q.",
  "repository": "github:ptarmiganlabs/ctrl-q-docs",
  "homepage": "https://ctrl-q.ptarmiganlabs.com",
  "author": "Ptarmigan Labs AB",
  "license": "Apache-2.0",
  "bugs": "https://github.com/ptarmiganlabs/ctrl-q/issues",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "pre:version": "node ./scripts/fetch-ctrl-q-version.mjs",
    "dev": "npm run pre:version && vitepress dev docs",
    "build": "npm run pre:version && vitepress build docs",
    "serve": "npm run pre:version && vitepress serve docs",
    "deploy": "gh workflow run deploy-vitepress.yml --ref $(git branch --show-current)",
    "migrate:hugo": "node ./scripts/migrate-hugo-to-vitepress.mjs"
  },
  "dependencies": {
    "medium-zoom": "^1.1.0"
  },
  "devDependencies": {
    "mermaid": "^11.14.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.33"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}
